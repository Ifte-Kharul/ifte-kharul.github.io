---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Contact"
  description="Direct contact links for Md. Ifte Kharul Islam via email, LinkedIn, and GitHub."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow" data-reveal>Contact</span>
      <h1 data-reveal>Reach me directly</h1>
      <p data-reveal>
        For role discussions, project collaboration, or technical conversations, direct channels work best.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <article class="surface-card contact-card" data-reveal>
        <small>Email</small>
        <strong><a href="mailto:iftekharul.tamim@gmail.com">iftekharul.tamim@gmail.com</a></strong>
        <p>Best for direct communication and role opportunities.</p>
      </article>

      <article class="surface-card contact-card" data-reveal>
        <small>LinkedIn</small>
        <strong>
          <a href="https://www.linkedin.com/in/md-ifte-kharul-islam/" target="_blank" rel="noopener noreferrer"
            >md-ifte-kharul-islam</a
          >
        </strong>
        <p>Professional timeline, updates, and network contact.</p>
      </article>

      <article class="surface-card contact-card" data-reveal>
        <small>GitHub</small>
        <strong><a href="https://github.com/Ifte-Kharul" target="_blank" rel="noopener noreferrer">Ifte-Kharul</a></strong>
        <p>Code repositories and public project history.</p>
      </article>
    </div>

    <div class="container" style="margin-top: 1rem;">
      <div class="button-row" data-reveal>
        <a class="button button-primary" href="mailto:iftekharul.tamim@gmail.com">Send Email</a>
        <a
          class="button button-secondary"
          href="/files/Md_Ifte_kharul_Islam_CSE_RUET.pdf"
          target="_blank"
          rel="noopener noreferrer"
          >Open CV PDF</a
        >
      </div>
    </div>
  </section>
</MainLayout>
