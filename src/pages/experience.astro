---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Experience"
  description="Professional timeline of Md. Ifte Kharul Islam across Staff Engineering, mobile product delivery, and backend API work."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow" data-reveal>Experience</span>
      <h1 data-reveal>Professional timeline and engineering scope</h1>
      <p data-reveal>
        This page summarizes role progression, delivery scope, and technical focus areas across product engineering,
        mobile implementation, and backend services.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container timeline">
      <article class="surface-card timeline-item" data-reveal>
        <p class="timeline-meta">Avian IT | Sept 2025 - Present | Dhaka, Bangladesh</p>
        <h2>Staff Software Engineer</h2>
        <ul class="info-list" style="margin-top: 0.7rem;">
          <li><strong>Role progression:</strong> Software Engineer -> Senior Software Engineer -> Staff Software Engineer</li>
          <li><strong>Primary scope:</strong> iOS delivery, Android alignment, and backend API contribution</li>
          <li><strong>Execution style:</strong> feature delivery with stability, performance, and maintainability focus</li>
        </ul>
      </article>

      <article class="surface-card timeline-item" data-reveal>
        <p class="timeline-meta">Jence | Feb 2025 - Aug 2025 | Dhaka, Bangladesh</p>
        <h2>Junior Software Engineer Trainee</h2>
        <ul class="info-list" style="margin-top: 0.7rem;">
          <li><strong>Embedded AI work:</strong> practical experiments around facial recognition and RFID workflows</li>
          <li><strong>Mobile work:</strong> Flutter app for RFID monitoring and control flows</li>
        </ul>
      </article>

      <article class="surface-card timeline-item" data-reveal>
        <p class="timeline-meta">ICT Division Training Program | Sept 2021 - Feb 2022 | Rajshahi, Bangladesh</p>
        <h2>Flutter Trainer</h2>
        <ul class="info-list" style="margin-top: 0.7rem;">
          <li><strong>Program type:</strong> national-level mobile app development training initiative</li>
          <li><strong>Teaching focus:</strong> cross-platform app development fundamentals and practical delivery habits</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container stack-grid">
      <article class="surface-card" data-reveal>
        <h3>Education</h3>
        <ul class="info-list" style="margin-top: 0.7rem;">
          <li><strong>RUET:</strong> BSc in Computer Science and Engineering (CGPA 3.16 / 4.0)</li>
          <li><strong>Cantonment Public School and College:</strong> HSC Science (GPA 5.00)</li>
          <li><strong>Nilphamari Govt High School:</strong> SSC Science (GPA 5.00)</li>
        </ul>
      </article>

      <article class="surface-card" data-reveal>
        <h3>Professional Highlights</h3>
        <ul class="info-list" style="margin-top: 0.7rem;">
          <li><strong>Delivery:</strong> production feature shipping with real user impact</li>
          <li><strong>Leadership:</strong> cross-platform collaboration between mobile teams</li>
          <li><strong>Engineering breadth:</strong> frontend mobile plus backend API execution</li>
        </ul>
      </article>
    </div>
  </section>
</MainLayout>
